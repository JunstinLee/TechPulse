# Product Hunt API Token (v2 Developer Token)
PH_API_TOKEN=YOUR_PH_API_TOKEN_HERE

# GitHub Personal Access Token (Increase API restrictions)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# Hugging Face Access Token (Optional, used to improve API rate limits)
#Address: https://huggingface.co/settings/tokens
HF_TOKEN=YOUR_HF_TOKEN_HERE

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

TG_BOT_TOKEN=YOUR_Telegram_Bot_Token_HERE

TG_CHAT_ID=YOUR_Telegram_Chat_ID_HERE

# Report listening directory (default is reports, used for Telegram automatic push)
REPORT_WATCH_DIR=reports

# Overview summary generation
OVERVIEW_ENABLED=true
OVERVIEW_AI_ENABLED=true
OVERVIEW_MODEL=z-ai/glm-4.5-air:free
OVERVIEW_MAX_INPUT_ITEMS=6
OVERVIEW_MAX_OUTPUT_CHARS=1200
OVERVIEW_INCLUDE_AI_COMMENT=true

# Channel AI Review: Maximum number of characters before writing to the report (0 = no truncation)
AI_COMMENT_MAX_CHARS=2000
# Streaming only uses delta.content; if the entire segment is empty, it backtracks and appends the reasoning field (default is false).
OPENROUTER_STREAM_FALLBACK_TO_REASONING=false
# Maximum number of tokens for channel analytics requests (aligned with short comment prompts)
AI_COMMENT_MAX_TOKENS=768
